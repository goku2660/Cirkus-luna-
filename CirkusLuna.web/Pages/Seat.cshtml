@page
@model CirkusLuna.Web.Pages.SeatModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Sædeoversigt</title>
    <style>
        body {
            font-family: Arial;
            margin: 0;
        }

        nav {
            background-color: darkred;
            padding: 15px 30px;
        }

            nav p {
                color: yellow;
                font-size: 20px;
                margin: 0;
            }

        .sektion {
            padding: 40px;
        }

        .scene {
            background-color: darkred;
            color: white;
            text-align: center;
            padding: 10px;
            margin-bottom: 20px;
            width: 420px;
        }

        .raekke {
            display: flex;
            align-items: center;
            margin-bottom: 8px;
            gap: 6px;
        }

        .raekke-label {
            width: 60px;
            font-weight: bold;
        }

        .saede {
            width: 36px;
            height: 36px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 11px;
            font-weight: bold;
        }

        .ledig {
            background-color: green;
            color: white;
        }

        .reserveret {
            background-color: gray;
            color: white;
            cursor: not-allowed;
        }

        .vip {
            background-color: gold;
            color: black;
        }

        .valgt {
            background-color: blue;
            color: white;
        }
        }

        .formular {
            background-color: lightgray;
            padding: 20px;
            margin-top: 24px;
            max-width: 420px;
        }

            .formular input {
                width: 100%;
                padding: 8px;
                margin-top: 6px;
                font-size: 14px;
            }

            .formular label {
                font-weight: bold;
                display: block;
                margin-top: 12px;
            }

            .formular button {
                background-color: darkred;
                color: white;
                padding: 10px 20px;
                border: none;
                cursor: pointer;
                margin-top: 16px;
            }

        .bekraeftet {
            background-color: lightgreen;
            padding: 16px;
            margin-top: 20px;
            max-width: 420px;
        }

        footer {
            background-color: darkred;
            color: white;
            text-align: center;
            padding: 20px;
            margin-top: 40px;
        }
    </style>
</head>
