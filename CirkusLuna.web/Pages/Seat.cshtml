                <button class="saede @Model.GetSaedeKlasse("R15S5")" name="SaedeNavn" value="R15S5" type="submit">5</button>
                <button class="saede @Model.GetSaedeKlasse("R15S6")" name="SaedeNavn" value="R15S6" type="submit">6</button>
                <button class="saede @Model.GetSaedeKlasse("R15S7")" name="SaedeNavn" value="R15S7" type="submit">7</button>
                <button class="saede @Model.GetSaedeKlasse("R15S8")" name="SaedeNavn" value="R15S8" type="submit">8</button>
                <button class="saede @Model.GetSaedeKlasse("R15S9")" name="SaedeNavn" value="R15S9" type="submit">9</button>
                <button class="saede @Model.GetSaedeKlasse("R15S10")" name="SaedeNavn" value="R15S10" type="submit">10</button>
            </div>
        </form>

        @if (Model.SaedeValgt)
        {
            <div class="formular">
                <h3>Valgt: @Model.SaedeNavn</h3>
                <form method="post" asp-page-handler="Bestil">
                    <input type="hidden" name="SaedeNavn" value="@Model.SaedeNavn" />
                    <label>Dit navn</label>
                    <input type="text" name="Navn" placeholder="Skriv dit navn" />
                    <label>Antal billetter</label>
                    <input type="number" name="Antal" value="1" min="1" max="10" />
                    <button type="submit">Bekraeft reservation</button>
                </form>
            </div>
        }

        @if (Model.Bekraeftet)
        {
            <div class="bekraeftet">
                <p>@Model.BekraeftetTekst</p>
            </div>
        }

    </div>
    <footer>
        <p>2026 Cirkus Luna</p>
    </footer>
</body>
</html>